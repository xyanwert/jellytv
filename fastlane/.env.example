# App Store Connect API key credentials for fastlane.
#
#   1. Copy this file to  fastlane/.env   (gitignored — never commit it)
#   2. In App Store Connect → Users and Access → Integrations → App Store Connect API,
#      create a Team Key with the "App Manager" role and download the .p8 once.
#   3. Store the .p8 OUTSIDE this repo and fill in the three values below.

# The 10-character Key ID shown next to the key.
ASC_KEY_ID=XXXXXXXXXX

# The Issuer ID (a UUID) shown at the top of the API keys page.
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the downloaded private key file.
ASC_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
